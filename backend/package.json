{
  "name": "shms-backend",
  "version": "1.0.0",
  "description": "Smart Health Monitoring System Backend - Node/Express/TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "db:generate": "prisma generate",
